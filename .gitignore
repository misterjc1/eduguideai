# ============================================================
# VENEEM - .gitignore combine (backend Spring Boot + frontend Angular)
# ============================================================

# --- Backend (Maven / Java) ---
backend/target/
backend/bin/
backend/build/
*.class
*.jar
*.war
*.ear

# --- Frontend (Angular / Node) ---
frontend/node_modules/
frontend/dist/
frontend/tmp/
frontend/out-tsc/
frontend/.angular/
frontend/coverage/
frontend/e2e/*.js
frontend/e2e/*.map
npm-debug.log
testem.log

# --- Secrets (cles de service, credentials) ---
**/djonan-firebase-account.json
*firebase-account*.json
*serviceAccount*.json

# --- Metadata SVN residuelle ---
.svn/

# --- IDE / editeurs ---
.idea/
*.iml
.project
.classpath
.settings/
.metadata/
.c9/
*.launch
*.sublime-workspace
*.sublime-project
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# --- Logs / temporaires ---
*.log
*.tmp
*.bak
*.swp
*.swo
*.swn
/connect.lock
libpeerconnection.log

# --- Systeme ---
.DS_Store
Thumbs.db

# --- Outils Claude Code (local, pas partage) ---
.claude/
.github/modernize/
